# Aurora production (IAM auth — Internet Access Gateway clusters)
#
# Setup:
#   cp env.aurora.example .env.aurora
#   Fill in AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY (belong-vercel IAM user)
#
# Migrate + seed:
#   npm run db:migrate:iam
#   npm run db:seed:iam
#
# Local app against Aurora (optional): remove DATABASE_URL from .env.local so IAM vars load.
# Vercel: add the same keys in Project → Settings → Environment Variables.

DATABASE_IAM_AUTH=true
DATABASE_HOST=database-1.cluster-cjymewgyahkl.us-east-2.rds.amazonaws.com
DATABASE_USER=postgres
DATABASE_NAME=postgres
DATABASE_PORT=5432
AWS_REGION=us-east-2

# Quote the secret — required if it contains / or +
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=""
